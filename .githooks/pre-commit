#!/bin/sh
set -e

echo "--- pre-commit ---"

echo "[1/3] fmt..."
UNFORMATTED=$(gofmt -l .)
if [ -n "$UNFORMATTED" ]; then
    echo "FAIL: unformatted files:"
    echo "$UNFORMATTED"
    echo "fix: gofmt -w ."
    exit 1
fi

echo "[2/3] vet..."
go vet ./...

echo "[3/3] test..."
go test -race -count=1 -timeout=60s ./...

echo "--- ok ---"
